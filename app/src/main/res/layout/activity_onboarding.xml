<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <ProgressBar
        android:id="@+id/pbOnboarding"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="8dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="44dp"
        android:max="100"
        android:progress="33"
        android:progressDrawable="@drawable/bg_onboarding_progress"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/vpOnboarding"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="96dp"
        app:layout_constraintTop_toBottomOf="@+id/pbOnboarding"
        app:layout_constraintBottom_toTopOf="@id/btnNext"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNext"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="244dp"
        android:backgroundTint="@color/white"
        android:fontFamily="@font/be_vietnam_pro_semibold"
        android:text="@string/next_button"
        android:textColor="@color/teal_dark"
        android:textSize="24sp"
        app:cornerRadius="12dp"
        app:icon="@drawable/icon_next_24"
        app:iconGravity="textEnd"
        app:iconSize="24dp"
        app:iconTint="@color/teal_dark"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="@color/mint_aqua"
        app:strokeWidth="1dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
